<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ProceduralSFXCompanion.App"
             xmlns:vm="using:ProceduralSFXCompanion.ViewModels"
             xmlns:ava="using:Avalonia.Themes.Simple"
             xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:conv="using:ProceduralSFXCompanion.Utilities"
             xmlns:local="using:ProceduralSFXCompanion"
             xmlns:sukiUi="clr-namespace:SukiUI;assembly=SukiUI"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
             
    <Application.Resources>
     <conv:PercentageConverter x:Key="PercentConv" />
     <x:Double x:Key="ControlContentThemeFontSize">16</x:Double>
     <SolidColorBrush x:Key="TextAreaSelectionBrush" Color="{DynamicResource SukiPrimaryColor}" Opacity="0.5"/>
    </Application.Resources>
             
    <Application.Styles>
        <!-- <SimpleTheme/> -->
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Simple/AvaloniaEdit.xaml" />
        
        <sukiUi:SukiTheme ThemeColor="Blue"  />
        <materialIcons:MaterialIconStyles />
        
        <StyleInclude Source="/Controls/TutorialCardStyle.axaml" />
        
        <Style Selector="Button">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.)" />
            <Setter Property="Opacity" Value="0.7" />
        </Style>
        
        <Style Selector="Button:pressed">
            <Setter Property="RenderTransform" Value="scale(0.95)" />
            <Setter Property="Opacity" Value="0.5" />
        </Style>
        
        <Style Selector="Button.Standard:pressed">
            <Setter Property="RenderTransform" Value="scale(1.)" />
            <Setter Property="Opacity" Value="0.5" />
        </Style>
        
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.25" />
        </Style>

        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource SukiPrimaryColor}"/>
            <Setter Property="Opacity" Value="0.8"/>
        </Style>

        <Style Selector="ComboBox:pressed">
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
        
    </Application.Styles>
             
</Application>